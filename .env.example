APP_NAME="ERP Learning Project"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Option A: MySQL (recommended)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=erp_learning
DB_USERNAME=root
DB_PASSWORD=

# Option B: PostgreSQL — change DB_CONNECTION to pgsql and update credentials
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=erp_learning
# DB_USERNAME=postgres
# DB_PASSWORD=

# Option C: SQLite (quickest for local dev, no server needed)
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database/database.sqlite

